# peasy-css-go — CSS minify, format, analyze (Go)
# Theme: Rose Pine
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "rose-pine"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-css-go — CSS minify, format, analyze for Go"
Enter
Type "# peasycss.com"
Enter
Sleep 500ms

# Run the demo
Type "go run ./examples/demo/"
Enter
Sleep 5s
